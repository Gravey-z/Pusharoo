{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "Pusharoo"
  },
  "NeoRpc": {
    "Endpoint": "https://mainnet1.neo.coz.io:443",
    "Network": "mainnet",
    "PollIntervalSeconds": 15,
    "MaxBlocksPerPoll": 10
  },
  "EventRelay": {
    "WebhookTimeoutSeconds": 15
  },
  "AllowedHosts": "*"
}
